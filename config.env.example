# Minecraft Bedrock Dedicated Server - Configuration
# Copy this file to config.env and edit to match your setup.

# --- Server Settings ---
SERVER_NAME="Minecraft Server"
WORLD_NAME="world"
GAMEMODE="survival"
DIFFICULTY="normal"
MAX_PLAYERS=10
VIEW_DISTANCE=32
SERVER_PORT=19132
SERVER_PORTV6=19133

# --- Paths ---
INSTALL_DIR="/opt/minecraft-bedrock"
BACKUP_DIR="/opt/minecraft-bedrock/backups"

# --- Service User ---
SERVICE_USER="minecraft"
SERVICE_GROUP="minecraft"

# --- Backups ---
BACKUP_KEEP_COUNT=20
BACKUP_CRON="15 3 * * *"

# --- Auto-Update ---
UPDATE_ENABLED=true
UPDATE_CRON="15 4 * * *"

# --- Email Notifications (optional) ---
# Requires msmtp or sendmail configured on the system
NOTIFY_ENABLED=false
NOTIFY_EMAIL=""
# Send email on every update check (not just failures). Useful for
# verifying that the update cron job and email delivery are working.
NOTIFY_ON_UPDATE_CHECK=false

# --- Existing World Import (optional) ---
# Set this to import an existing world on first install.
# Path to a world directory or a zip file containing one.
IMPORT_WORLD=""
# Path to an existing server.properties to import
IMPORT_SERVER_PROPERTIES=""
