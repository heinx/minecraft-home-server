# Test configuration for Minecraft Bedrock Dedicated Server
# Used by the Vagrant-based test suite.

# --- Server Settings ---
SERVER_NAME="Test Server"
WORLD_NAME="TestWorld"
GAMEMODE="survival"
DIFFICULTY="normal"
MAX_PLAYERS=10
VIEW_DISTANCE=32
SERVER_PORT=19132
SERVER_PORTV6=19133

# --- Paths ---
INSTALL_DIR="/opt/minecraft-bedrock"
BACKUP_DIR="/opt/minecraft-bedrock/backups"

# --- Service User ---
SERVICE_USER="minecraft"
SERVICE_GROUP="minecraft"

# --- Backups ---
BACKUP_KEEP_COUNT=20
BACKUP_CRON="15 3 * * *"

# --- Cloud Backup (disabled for tests) ---
CLOUD_BACKUP_ENABLED=false
CLOUD_BACKUP_REMOTE=""
CLOUD_BACKUP_FOLDER=""

# --- Auto-Update ---
UPDATE_ENABLED=true
UPDATE_CRON="15 4 * * *"

# --- Email Notifications (disabled for tests) ---
NOTIFY_ENABLED=false
NOTIFY_EMAIL=""
