# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# Apple Silicon (M1/M2): use Lima instead — much faster (~30s vs ~10min):
#   cd tests && make up && make test && make destroy
#   See tests/Makefile and tests/lima.yaml
#
# Intel Mac / Linux / CI: use this Vagrantfile
#   vagrant up --provider=qemu    (or virtualbox)

Vagrant.configure("2") do |config|
  config.vm.box = "generic/ubuntu2204"

  config.vm.provider "qemu" do |qe|
    qe.memory = "2G"
    qe.smp = "2"
    qe.arch = "x86_64"
    qe.machine = "q35"
    qe.cpu = "max"
    qe.net_device = "virtio-net-pci"
  end

  config.vm.provider "virtualbox" do |vb|
    vb.memory = 2048
    vb.cpus = 2
    vb.name = "minecraft-bedrock-tests"
  end

  # Sync repo root into the VM
  config.vm.synced_folder "..", "/vagrant", type: "rsync"

  # Forward Bedrock server UDP port for manual verification
  config.vm.network "forwarded_port", guest: 19132, host: 19132, protocol: "udp"

  # Provision the VM
  config.vm.provision "shell", path: "provision.sh"
end
